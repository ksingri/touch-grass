{
  "manifest_version": 2,
  "name": "Touch Grass",
  "version": "1.0.0",
  "description": "Block doom scrolling sites and reclaim your peace of mind.",
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "storage",
    "*://*.linkedin.com/*",
    "*://*.instagram.com/*",
    "*://*.threads.net/*",
    "*://*.threads.com/*",
    "*://*.drudgereport.com/*",
    "*://*.reddit.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Touch Grass",
    "default_icon": {
      "48": "icons/icon.svg"
    }
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "content_scripts": [
    {
      "matches": ["*://*.reddit.com/*"],
      "js": ["reddit-guard.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    "blocked.html",
    "blocked.css",
    "blocked.js"
  ]
}
